# Numeric GA4 property id for Disruption Joe - GA4.
# The CLI can also help list accessible properties:
# npm run analytics -- properties
GA4_PROPERTY_ID=362548326

# Preferred local auth option:
# Use Application Default Credentials (ADC) for local development.
# Google Analytics' official MCP/docs use the same underlying pattern.
# Typical local flow:
# 1. Install Google Cloud SDK (gcloud)
# 2. Run the ADC login flow documented in tools/analytics-cli.md
# 3. Leave GOOGLE_APPLICATION_CREDENTIALS unset unless you want an explicit override

# Advanced / override auth option:
# Point this at a local credentials JSON file that is not committed.
# This can be a service-account JSON, or an ADC credentials file path if needed.
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\credentials.json

# Optional explicit credential alternatives:
# GA4_CLIENT_EMAIL=ga4-reader@your-project.iam.gserviceaccount.com
# GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GA4_SERVICE_ACCOUNT_JSON={"client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}

# Contact / CRM intake
# Twenty is the system of record for post-identification leads and webinar registrations.
TWENTY_API_KEY=
TWENTY_API_URL=https://api.twenty.com

# Optional: set this so webinar registrations create a WebinarParticipation record
# against the seeded live webinar in Twenty.
TWENTY_DEFAULT_WEBINAR_ID=

# Optional: notification email wiring for contact submissions.
# RESEND_API_KEY=
# CONTACT_NOTIFY_FROM_EMAIL=
# CONTACT_NOTIFY_TO_EMAIL=joe@disruptionjoe.com

# Optional: confirmation-first acknowledgment emails for website contact submissions.
# These stay disabled by default. Keep preview mode on while reviewing copy / trigger rules.
CONTACT_CONFIRMATION_EMAILS_ENABLED=false
CONTACT_CONFIRMATION_PREVIEW_ONLY=true
# CONTACT_CONFIRMATION_FROM_EMAIL=
