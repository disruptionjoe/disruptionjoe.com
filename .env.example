# Set this once you know the numeric GA4 property id.
# If you do not know it yet, the CLI can help list accessible properties:
# npm run analytics -- properties
GA4_PROPERTY_ID=123456789

# Preferred local auth option:
# Point this at a local Google service account JSON file that is not committed.
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\ga4-service-account.json

# Optional alternative to GOOGLE_APPLICATION_CREDENTIALS:
# GA4_CLIENT_EMAIL=ga4-reader@your-project.iam.gserviceaccount.com
# GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
